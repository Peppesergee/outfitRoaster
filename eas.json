{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://192.168.1.11:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "REPLACE_WITH_RAILWAY_URL"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "REPLACE_WITH_RAILWAY_URL"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID",
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID"
      }
    }
  }
}
